# ── Hedera Credentials ────────────────────────────────────────────────────────
# Create a testnet account at https://portal.hedera.com
HEDERA_ACCOUNT_ID=0.0.XXXXXX
HEDERA_PRIVATE_KEY=your_ecdsa_private_key_hex_here
HEDERA_NETWORK=testnet

# ── Anthropic API ──────────────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXX

# ── Hedera Resource IDs (auto-populated on first run) ─────────────────────────
# Leave blank — the server will create these and print the IDs on first startup.
# After first run, paste the printed values here to reuse across restarts.
HCS_TOPIC_ID=
HTS_TOKEN_ID=

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3001
